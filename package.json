{
  "name": "nagi-group",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "bun run build:content && vite build",
    "build:content": "bun run scripts/validate-content.ts && bun run scripts/build-graph.ts && bun run scripts/build-search-index.ts",
    "validate": "bun run scripts/validate-content.ts",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json"
  },
  "devDependencies": {
    "@sveltejs/adapter-vercel": "^5.7.0",
    "@sveltejs/kit": "^2.21.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "svelte": "^5.28.0",
    "svelte-check": "^4.1.0",
    "typescript": "^5.8.0",
    "vite": "^6.2.0"
  },
  "dependencies": {
    "@types/d3-force": "^3.0.10",
    "ajv": "^8.17.0",
    "ajv-formats": "^3.0.1",
    "d3-force": "^3.0.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "minisearch": "^7.1.0",
    "rehype-stringify": "^10.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.0.0",
    "unified": "^11.0.0"
  },
  "type": "module"
}
