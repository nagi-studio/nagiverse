{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "UserProfile",
  "type": "object",
  "required": ["id", "name", "links"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$",
      "description": "Unique user identifier, must match directory name"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Display name"
    },
    "bio": {
      "type": "string",
      "description": "Short biography"
    },
    "avatar": {
      "type": "string",
      "description": "URL to avatar image"
    },
    "links": {
      "type": "object",
      "required": ["github"],
      "properties": {
        "github": {
          "type": "string",
          "format": "uri",
          "description": "GitHub profile URL (required)"
        }
      },
      "additionalProperties": {
        "type": "string",
        "format": "uri"
      },
      "description": "Social links. github is required; optional: bilibili, x, zhihu, blog, etc."
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true,
      "description": "Interest tags"
    }
  }
}
