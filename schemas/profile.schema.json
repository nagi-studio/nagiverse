{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "UserProfile",
  "type": "object",
  "required": ["id", "name"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$",
      "description": "Unique user identifier, must match directory name"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Display name"
    },
    "bio": {
      "type": "string",
      "description": "Short biography"
    },
    "avatar": {
      "type": "string",
      "description": "URL to avatar image"
    },
    "links": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "format": "uri"
      },
      "description": "Named links (e.g. github, twitter)"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true,
      "description": "Interest tags"
    }
  }
}
